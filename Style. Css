/* ===========================
   AgMarketReport Version 1
=========================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{

    font-family:Arial, Helvetica, sans-serif;

    background:#eef3ea;

    color:#222;

    line-height:1.5;
}

/* HEADER */

.hero{

    background:linear-gradient(90deg,#1b5e20,#2e7d32,#558b2f);

    color:white;

    text-align:center;

    padding:40px 20px;

    box-shadow:0 4px 15px rgba(0,0,0,.25);

}

.hero h1{

    font-size:48px;

    margin-bottom:10px;

}

.hero h2{

    font-size:22px;

    font-weight:normal;

    opacity:.95;

}

#darkModeBtn{

    margin-top:20px;

    border:none;

    border-radius:30px;

    padding:12px 30px;

    cursor:pointer;

    background:white;

    color:#2e7d32;

    font-size:16px;

    font-weight:bold;

}

#darkModeBtn:hover{

    background:#ffd54f;

}

/* CONTAINER */

.container{

    width:95%;

    max-width:1500px;

    margin:auto;

    padding:30px;

}

/* GOOD MORNING */

.banner{

    display:flex;

    justify-content:space-between;

    align-items:center;

    flex-wrap:wrap;

    margin-bottom:30px;

}

.banner h2{

    font-size:34px;

}

.banner p{

    font-size:18px;

}

.mood{

    background:white;

    border-radius:15px;

    padding:20px;

    text-align:center;

    box-shadow:0 4px 10px rgba(0,0,0,.15);

}

/* GRID */

.grid{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(450px,1fr));

    gap:25px;

}

/* CARDS */

.card{

    background:white;

    border-radius:18px;

    padding:25px;

    box-shadow:0 6px 18px rgba(0,0,0,.12);

}

.card h2{

    color:#1b5e20;

    margin-bottom:18px;

    border-bottom:2px solid #d8d8d8;

    padding-bottom:8px;

}

/* TABLE */

table{

    width:100%;

    border-collapse:collapse;

}

th{

    background:#2e7d32;

    color:white;

    padding:12px;

}

td{

    padding:10px;

    border-bottom:1px solid #dddddd;

}

tr:hover{

    background:#f4f4f4;

}

/* WEATHER */

.weather{

    text-align:center;

}

.weather h3{

    font-size:40px;

    color:#ff9800;

}

/* FOOTER */

footer{

    text-align:center;

    margin-top:40px;

    color:#666;

    padding-bottom:30px;

}

footer hr{

    margin-bottom:20px;

}

/* DARK MODE */

.dark{

    background:#111;

    color:white;

}

.dark .card{

    background:#222;

    color:white;

}

.dark th{

    background:#4caf50;

}

.dark td{

    border-bottom:1px solid #444;

}

.dark .hero{

    background:linear-gradient(90deg,#111,#1b5e20,#2e7d32);

}

/* MOBILE */

@media(max-width:800px){

.hero h1{

font-size:34px;

}

.banner{

flex-direction:column;

gap:20px;

}

.grid{

grid-template-columns:1fr;

}

.card{

padding:18px;

}

}
