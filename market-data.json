fetch("market-data.json")

.then(response => response.json())

.then(data => {

    const bids = data.ritzville.cashBids;

    if (bids.length >= 4){

        document.getElementById("softWhite").textContent =
            "$" + bids[0].price;

        document.getElementById("white12").textContent =
            "$" + bids[1].price;

        document.getElementById("hrw").textContent =
            "$" + bids[2].price;

        document.getElementById("dns").textContent =
            "$" + bids[3].price;

    }

});
